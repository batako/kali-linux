tmp/*

# p10k prompt (personal — run p10k configure in container)
dotfiles/zsh/.p10k.zsh

# Local env (docker-compose secrets, API keys)
.env

# Local Docker Compose configuration (copy docker-compose.yml.example first)
docker-compose.yml

# Local tool checkout
tools/

# ctx runtime state (keep only the checked-in example config)
dotfiles/ctx/.ctx/*
!dotfiles/ctx/.ctx/config.toml.example

# OpenVPN (contains credentials; place .ovpn locally)
config/openvpn/*.ovpn

# Python
__pycache__/
*.pyc

# workspace: exploits/recon gitignored; payloads = self-authored, tracked
workspace/exploits/**
!workspace/exploits/**/.keep

# Recon CLI runtime DB (recon/data/ also holds tracked nmap-top-1000-tcp.txt)
recon/data/recon.db
recon/data/recon.db.lock
recon/data/recon.db-*

workspace/cases/**
!workspace/cases/**/
!workspace/cases/**/.keep
