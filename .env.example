# ------------------------------------------------------------------
# Required
# ------------------------------------------------------------------

# VNC password
VNC_PASSWORD=kali1234

# ------------------------------------------------------------------
# Optional integrations
# ------------------------------------------------------------------

# WPScan API token
# Create a free account at https://wpscan.com/
# Then generate an API token from your account dashboard.
#
# The toolkit works without an API token, but vulnerability
# correlation and CVE information will be unavailable.
WPSCAN_API_TOKEN=

# ------------------------------------------------------------------
# User preferences
# ------------------------------------------------------------------

# Language for custom CLI tools
# Supported values: ja, en
# Default: en
TOOLKIT_LANG=
